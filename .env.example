# Meta Ads Scraper — Environment Variables
# Copy this file to .env (gitignored) and fill in real values where needed.

# ─── Live testing ────────────────────────────────────────────────
# Set to 1 to enable smoke tests that hit real Meta.
# CI defaults this to 0; only enable for manual smoke runs locally.
META_LIVE_TESTS=0

# ─── Rate limiting ───────────────────────────────────────────────
# Requests per second (float). Keep low to avoid blocks.
META_RATE_LIMIT=1.0

# Max concurrent browser tabs. Default 1.
META_CONCURRENCY=1

# ─── Behaviour ───────────────────────────────────────────────────
# Default max results per run (None=unlimited up to 1000 hard cap).
META_DEFAULT_MAX_RESULTS=

# Default timeout in seconds.
META_DEFAULT_TIMEOUT=300

# Default scroll-stall threshold.
META_STALL_THRESHOLD=3

# ─── Future: Path A (Meta Graph API) ─────────────────────────────
# Not required for MVP. Reserved for Phase 8+.
# META_ACCESS_TOKEN=
# META_APP_ID=

# ─── Logging ─────────────────────────────────────────────────────
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
